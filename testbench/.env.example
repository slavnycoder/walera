# testbench/.env.example
# Copy to testbench/.env (gitignored). Dev-only values; never production secrets.
COMPOSE_PROJECT_NAME=walera-testbench
POSTGRES_PASSWORD=walera
PG_HOST_PORT=5432
MOCK_AUTH_PORT=9000     # internal port — NOT host-published; informational.

# Plan 06-03 / Phase 06 additions.
# Host port for the walera SSE listener — bound to 127.0.0.1 only (loopback).
# Override if 8080 collides with another local service.
WALERA_HOST_PORT=8080

# Optional overrides for walera env vars baked into docker-compose.yml. The
# compose file uses ${VAR:-default} substitution, so unset values keep the
# documented defaults below.
# WALERA_HTTP_CORS_ORIGINS=http://localhost:8081      # comma-separated allowlist; single-value path tested in internal/config

# Plan 07-03 / Phase 07 addition.
# Host port for the writer HTTP control + metrics surface — bound to 127.0.0.1
# only (loopback). Writer /control endpoint is unauthenticated; localhost-bind
# is the security boundary (Threat T-07-09). Override only if 9100 collides
# locally; NEVER bind to 0.0.0.0.
WRITER_HOST_PORT=9100

# Optional overrides for the writer environment (compose substitutes
# ${VAR:-default}, so unset values keep documented defaults).
# WRITER_LOG_LEVEL=info
# WRITER_ARRIVALS_DISTRIBUTION=poisson         # or "uniform"
# Plan 08-04 / UI-08: CORS allowlist for POST /control + OPTIONS preflight.
# Comma-separated string; default in compose is http://localhost:8081 (Caddy
# frontend). Empty disables CORS (preserves pre-08-04 behaviour).
# WRITER_HTTP_CORS_ORIGINS=http://localhost:8081

# Plan 08-01 / Phase 08 addition.
# Host port for the demo-UI Caddy static server — bound to 127.0.0.1 only
# (loopback). Override only if 8081 collides locally; NEVER bind to 0.0.0.0
# (the demo UI is a localhost dev tool and CORS/origin checks on walera
# allow exactly `http://localhost:8081`).
FRONTEND_HOST_PORT=8081

# Plan 09-01 / Phase 09 addition.
# Host port for the Prometheus HTTP surface (scrape + /-/healthy + /api/v1/*) —
# bound to 127.0.0.1 only (loopback). Override only if 9090 collides locally;
# NEVER bind to 0.0.0.0 (default Prometheus has no auth on its HTTP surface).
PROM_HOST_PORT=9090

# Plan 09-02 / Phase 09 addition.
# Host port for Grafana — bound to 127.0.0.1 only (loopback). Anonymous Viewer
# is enabled by default for the demo; NEVER bind to 0.0.0.0 (would publish an
# unauthenticated read surface to the LAN). Override only if 3000 collides.
GRAFANA_HOST_PORT=3000

# Admin escape hatch for dashboard write-edits during development. The compose
# fallback default "admin" is the well-known upstream Grafana credential —
# acceptable ONLY because the Grafana listener is bound to 127.0.0.1 and the
# login form is hidden behind /login?disableLoginForm=false. If you intend to
# rebind Grafana to a non-loopback interface, or run this stack on a shared
# dev host, uncomment the line below and set a non-default value FIRST. Log
# in via http://127.0.0.1:3000/login?disableLoginForm=false.
# GF_SECURITY_ADMIN_PASSWORD=walera-demo-changeme
